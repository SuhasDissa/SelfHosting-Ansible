server {
    listen 80;
    listen [::]:80;
    server_name torrent.{{ domain }};

    access_log /var/log/nginx/torrent.access.log;
    error_log /var/log/nginx/torrent.error.log;

    # Proxy to Transmission
    location / {
        proxy_pass http://127.0.0.1:{{ ports.transmission_web }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Transmission specific headers
        proxy_http_version 1.1;
        proxy_set_header X-Forwarded-Host $http_host;
    }
}
