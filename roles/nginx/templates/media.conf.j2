server {
    listen 80;
    listen [::]:80;
    server_name media.{{ domain }};

    access_log /var/log/nginx/media.access.log;
    error_log /var/log/nginx/media.error.log;

    # Increase timeouts for transcoding
    proxy_read_timeout 300s;
    proxy_connect_timeout 75s;

    # Proxy to Jellyfin
    location / {
        proxy_pass http://127.0.0.1:{{ ports.jellyfin }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $http_host;
        
        # Jellyfin WebSocket support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        
        # Disable buffering for transcoding
        proxy_buffering off;
    }
}
